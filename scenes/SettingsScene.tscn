[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/SettingsMenuUI.gd" id="1_settings"]

[node name="SettingsScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_settings")

[node name="Backdrop" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.05, 0.06, 0.08, 0.92)

[node name="Panel" type="Panel" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -180.0
offset_right = 220.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2

[node name="Margin" type="MarginContainer" parent="Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 28
theme_override_constants/margin_top = 28
theme_override_constants/margin_right = 28
theme_override_constants/margin_bottom = 28

[node name="VBox" type="VBoxContainer" parent="Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 28
text = "Settings"

[node name="FpsLabel" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
text = "Frame rate limit"

[node name="FpsOption" type="OptionButton" parent="Panel/Margin/VBox"]
custom_minimum_size = Vector2(0, 36)
layout_mode = 2

[node name="QualityLabel" type="Label" parent="Panel/Margin/VBox"]
layout_mode = 2
text = "Quality preset"

[node name="QualityOption" type="OptionButton" parent="Panel/Margin/VBox"]
custom_minimum_size = Vector2(0, 36)
layout_mode = 2

[node name="BackButton" type="Button" parent="Panel/Margin/VBox"]
custom_minimum_size = Vector2(0, 44)
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Back"

[connection signal="item_selected" from="Panel/Margin/VBox/FpsOption" to="." method="_on_fps_changed"]
[connection signal="item_selected" from="Panel/Margin/VBox/QualityOption" to="." method="_on_quality_changed"]
[connection signal="pressed" from="Panel/Margin/VBox/BackButton" to="." method="_on_back_pressed"]
